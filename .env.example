# Copy to apps/api/.env and adjust paths if needed

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

PIPELINE_VERSION=0.1.0
DATA_CONTRACT_VERSION=1.0.0

# Empty = auto-detect repo root (dashboard_MexIHC). Override if the API runs elsewhere.
RESEARCH_DATA_ROOT=

# Feature matrix used to train stress / cognitive-load models (NOT included in this repo).
# Place the file at models/training_features_core10.csv or set the full path here.
TRAINING_FEATURES_CSV=
